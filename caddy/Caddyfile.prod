curlme.dev, api.curlme.dev {
  # WebSocket traffic - no gzip, no buffering
  handle /ws/* {
    reverse_proxy curlme-api:8000 {
      flush_interval -1
    }
  }

  # Regular API traffic
  handle {
    encode gzip
    reverse_proxy curlme-api:8000
  }

  rate_limit {
    zone api_limit {
      key {remote_host}
      events 100
      window 1m
    }

    zone burst_limit {
      key {remote_host}
      events 10
      window 1s
    }
  }
}
